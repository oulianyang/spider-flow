# ============================================================
# spider-flow 环境变量配置模板
# ============================================================
# 使用方式: 复制此文件为 .env 并修改为实际值
# ============================================================

# === MySQL 配置 ===
MYSQL_ROOT_PASSWORD=spiderflow
MYSQL_PORT=3306

# === 应用配置 ===
APP_PORT=8088

# === JVM 参数（可选，取消注释后生效）===
# JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseG1GC
